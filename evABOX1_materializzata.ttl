@prefix : <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-39#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-39> .

<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-39> rdf:type owl:Ontology ;
                                                                           <http://purl.org/dc/elements/1.1/title> "Ontologia delle Infrastrutture di Ricarica per Veicoli Elettrici nelle Smart Cities"@it ,
                                                                                                                   "Ontologia per la modellazionedi aree di ricarica in contesto urbano"@it ;
                                                                           <http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#coversRequirements> "What is the context or situation of something? What are the things present in this context or situation?" ;
                                                                           <http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#extractedFrom> "http://www.ontologydesignpatterns.org/ont/dul/DUL.owl" ;
                                                                           <http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#hasAuthor> "Aldo Gangemi" ;
                                                                           <http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#hasConsequences> """We can contextualize things that have something in common, or are associated: a same place, time, view, causal link, systemic dependence, etc.
We can also reify n-ary relations as situations.""" ;
                                                                           <http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#hasIntent> "To represent contexts or situations, and the things that are contextualized." ;
                                                                           <http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#scenarios> "The lecture was held in January 1921 by Bela Fleck, with some physicians in the audience making questions, in a very relaxed athmosphere." ;
                                                                           rdfs:label "Andrea Lai"@it ,
                                                                                      "EV Charging Infrastructure Ontology"@en ,
                                                                                      "evcharge"@en ,
                                                                                      "situation" ,
                                                                                      "2026-06-13T00:00:00"^^xsd:dateTime ;
                                                                           owl:versionInfo "1.1 added rdfs:isDefinedBy for all named entities" ,
                                                                                           "Created by Aldo Gangemi and Valentina Presutti" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


###  http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#coversRequirements
<http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#coversRequirements> rdf:type owl:AnnotationProperty ;
                                                                                          rdfs:comment "This annotation property is used for exemplifying possible requirements the content pattern provides a solution for. Requirements are expressed as natural language competency questions." .


###  http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#extractedFrom
<http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#extractedFrom> rdf:type owl:AnnotationProperty ;
                                                                                     rdfs:comment "This annotation property should be assigned with a URI, which points to the possible reference ontology which the annotated pattern was extracted from (i.e. the reference ontology that the ontology elements have been deeply or partially cloned by). The range is not explicit in the definition of the annotation property because it would turn the ontology to OWL Full. E.g. The participation pattern is extracted from the Dolce Ultra Lite ontology, hence the value for this annotation property is http://www.ontologydesignpatterns.org/ont/dul/DUL.owl" .


###  http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#hasAuthor
<http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#hasAuthor> rdf:type owl:AnnotationProperty .


###  http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#hasConsequences
<http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#hasConsequences> rdf:type owl:AnnotationProperty ;
                                                                                       rdfs:comment "This annotation property is used for briefly describing the benefits and/or possible trade-offs when using the CP." .


###  http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#hasIntent
<http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#hasIntent> rdf:type owl:AnnotationProperty ;
                                                                                 rdfs:comment "This annotation property is used in order to describe the intent of the content pattern." .


###  http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#scenarios
<http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#scenarios> rdf:type owl:AnnotationProperty ;
                                                                                 rdfs:comment "This annotation property is used for describing examples of instantiation of the Content OP. For example, for the part-of Content OP (which represents part-whole relations) a possible scenario is the sentence: \"the brain is part of the human body\". Scenarios are expressed as natural language sentences." .


#################################################################
#    Object Properties
#################################################################

###  http://www.ontologydesignpatterns.org/cp/owl/situation.owl#hasSetting
<http://www.ontologydesignpatterns.org/cp/owl/situation.owl#hasSetting> rdf:type owl:ObjectProperty ;
                                                                        owl:inverseOf <http://www.ontologydesignpatterns.org/cp/owl/situation.owl#isSettingFor> ;
                                                                        rdfs:domain owl:Thing ;
                                                                        rdfs:range <http://www.ontologydesignpatterns.org/cp/owl/situation.owl#Situation> ;
                                                                        rdfs:comment "A relation between entities and situations, e.g. 'this morning I've prepared my coffee with a new fantastic Arabica' (i.e.: (an amount of) a new fantastic Arabica hasSetting the preparation of my coffee this morning)." ;
                                                                        rdfs:isDefinedBy <http://www.ontologydesignpatterns.org/cp/owl/situation.owl> ;
                                                                        rdfs:label "has setting"@en .


###  http://www.ontologydesignpatterns.org/cp/owl/situation.owl#isSettingFor
<http://www.ontologydesignpatterns.org/cp/owl/situation.owl#isSettingFor> rdf:type owl:ObjectProperty ;
                                                                          rdfs:domain <http://www.ontologydesignpatterns.org/cp/owl/situation.owl#Situation> ;
                                                                          rdfs:range owl:Thing ;
                                                                          rdfs:isDefinedBy <http://www.ontologydesignpatterns.org/cp/owl/situation.owl> ;
                                                                          rdfs:label "is setting for"@en .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/contiene
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/contiene> rdf:type owl:ObjectProperty ;
                                                                                   owl:inverseOf <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/èContenutoIn> ;
                                                                                   rdf:type owl:TransitiveProperty ;
                                                                                   rdfs:comment "Relazione generica di contenimento tra elementi dell'infrastruttura di ricarica."@it ;
                                                                                   rdfs:label "contiene"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/contieneColonnina
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/contieneColonnina> rdf:type owl:ObjectProperty ;
                                                                                            rdfs:subPropertyOf <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/contiene> ,
                                                                                                               [ owl:inverseOf <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/èContenutoIn>
                                                                                                               ] ;
                                                                                            rdfs:domain <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StazioneDiRicarica> ;
                                                                                            rdfs:range <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/PuntoDiRicarica> ;
                                                                                            rdfs:comment "Collega una stazione di ricarica ai punti di ricarica che la compongono."@it ;
                                                                                            rdfs:label "contiene punto di ricarica"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/contieneConnettore
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/contieneConnettore> rdf:type owl:ObjectProperty ;
                                                                                             rdfs:subPropertyOf <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/contiene> ,
                                                                                                                [ owl:inverseOf <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/èContenutoIn>
                                                                                                                ] ;
                                                                                             rdfs:domain <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/PuntoDiRicarica> ;
                                                                                             rdfs:range <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/Connettore> ;
                                                                                             rdfs:comment "Collega un punto di ricarica ai connettori disponibili."@it ;
                                                                                             rdfs:label "contiene connettore"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/contieneStazione
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/contieneStazione> rdf:type owl:ObjectProperty ;
                                                                                           rdfs:subPropertyOf <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/contiene> ,
                                                                                                              [ owl:inverseOf <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/èContenutoIn>
                                                                                                              ] ;
                                                                                           rdfs:domain <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/AreaDiRicarica> ;
                                                                                           rdfs:range <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StazioneDiRicarica> ;
                                                                                           rdfs:comment "Collega un'area di ricarica alle stazioni presenti al suo interno."@it ;
                                                                                           rdfs:label "contiene stazione di ricarica"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/haConnettoreInCitta
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/haConnettoreInCitta> rdf:type owl:ObjectProperty ;
                                                                                              owl:propertyChainAxiom ( <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/haInstallatoArea>
                                                                                                                       <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/contieneStazione>
                                                                                                                       <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/contieneColonnina>
                                                                                                                       <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/contieneConnettore>
                                                                                                                     ) ;
                                                                                              rdfs:comment "Relazione inferita che collega una città ai connettori presenti nelle aree di ricarica installate sul suo territorio."@it ;
                                                                                              rdfs:label "ha connettore nella città"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/haInstallatoArea
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/haInstallatoArea> rdf:type owl:ObjectProperty ;
                                                                                           owl:inverseOf <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/èInstallataInCitta> ;
                                                                                           rdfs:domain <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/Citta> ;
                                                                                           rdfs:range <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/AreaDiRicarica> ;
                                                                                           rdfs:comment "Collega una città alle aree di ricarica presenti nel suo territorio."@it ;
                                                                                           rdfs:label "ha installato area di ricarica"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/haStato
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/haStato> rdf:type owl:ObjectProperty ;
                                                                                  rdfs:domain <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StatoStazione> ;
                                                                                  rdfs:range <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StatoOperativo> .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/haTipologiaCorrente
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/haTipologiaCorrente> rdf:type owl:ObjectProperty ,
                                                                                                       owl:FunctionalProperty ;
                                                                                              rdfs:domain <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StazioneDiRicarica> ;
                                                                                              rdfs:range <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/TipologiaCorrente> ;
                                                                                              rdfs:comment "Specifica la tipologia di corrente utilizzata da una stazione di ricarica."@it ;
                                                                                              rdfs:label "ha tipologia di corrente"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/èContenutoIn
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/èContenutoIn> rdf:type owl:ObjectProperty ;
                                                                                       rdfs:comment "Relazione inversa di contiene che indica l'elemento contenitore di una risorsa"@it ;
                                                                                       rdfs:label "è contenuto in"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/èInProvincia
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/èInProvincia> rdf:type owl:ObjectProperty ;
                                                                                       rdfs:domain <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/Citta> ;
                                                                                       rdfs:range <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/Provincia> ;
                                                                                       rdfs:comment "Indica la provincia in cui è situata la città"@it ;
                                                                                       rdfs:label "appartiene a provincia"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/èInstallataInCitta
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/èInstallataInCitta> rdf:type owl:ObjectProperty ,
                                                                                                      owl:FunctionalProperty ;
                                                                                             rdfs:domain <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/AreaDiRicarica> ;
                                                                                             rdfs:range <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/Citta> ;
                                                                                             rdfs:comment "Collega un'area di ricarica alla città in cui è ubicata."@it ;
                                                                                             rdfs:label "è installata nella città"@it .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/haPotenzaMassima
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/haPotenzaMassima> rdf:type owl:DatatypeProperty ,
                                                                                                    owl:FunctionalProperty ;
                                                                                           rdfs:domain <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/AreaDiRicarica> ;
                                                                                           rdfs:range xsd:decimal .


###  http://www.w3.org/2003/01/geo/wgs84_pos#lat
<http://www.w3.org/2003/01/geo/wgs84_pos#lat> rdf:type owl:DatatypeProperty ;
                                              rdfs:comment "Coordinata geografica di latitudine dell'entità spaziale."@it ;
                                              rdfs:label "latitudine"@it .


###  http://www.w3.org/2003/01/geo/wgs84_pos#long
<http://www.w3.org/2003/01/geo/wgs84_pos#long> rdf:type owl:DatatypeProperty ;
                                               rdfs:comment "Coordinata geografica di longitudine dell'entità spaziale."@it ;
                                               rdfs:label "longitudine"@it .


#################################################################
#    Classes
#################################################################

###  http://schema.org/City
<http://schema.org/City> rdf:type owl:Class ;
                         owl:equivalentClass <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/Citta> .


###  http://schema.org/Organization
<http://schema.org/Organization> rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/cp/owl/situation.owl#Situation
<http://www.ontologydesignpatterns.org/cp/owl/situation.owl#Situation> rdf:type owl:Class ;
                                                                       rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                         owl:onProperty <http://www.ontologydesignpatterns.org/cp/owl/situation.owl#isSettingFor> ;
                                                                                         owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                                                       ] ;
                                                                       rdfs:comment """A view on a set of entities. It can be seen as a 'relational context', reifying a relation.
For example, a PlanExecution is a context including some actions executed by agents according to certain parameters and expected tasks to be achieved from a Plan; a DiagnosedSituation is a context of observed entities that is interpreted on the basis of a Diagnosis, etc.
Situation is also able to represent reified n-ary relations, where isSettingFor is the top-level relation for all binary projections of the n-ary relation. If used in a transformation pattern for n-ary relations, the designer should take care of:
- creating only one situation for each instance of an n-ary relation, otherwise the 'identification constraint' (Calvanese et al., IJCAI 2001) could be violated
- adding an 'exact cardinality' restriction corresponding to the arity of the n-ary relation, otherwise the designer would actually represent a polymorphic relation.""" ;
                                                                       rdfs:isDefinedBy <http://www.ontologydesignpatterns.org/cp/owl/situation.owl> ;
                                                                       rdfs:label "Situation"@en .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/AreaDiRicarica
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/AreaDiRicarica> rdf:type owl:Class ;
                                                                                         rdfs:subClassOf <http://www.w3.org/2003/01/geo/wgs84_pos#SpatialThing> ;
                                                                                         rdfs:comment "sito fisico che ospita una o più stazioni di ricarica per veicoli elettrici"@it ;
                                                                                         rdfs:label "Area di ricarica"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/ChargingPointOperator
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/ChargingPointOperator> rdf:type owl:Class ;
                                                                                                rdfs:subClassOf <http://schema.org/Organization> ;
                                                                                                rdfs:comment "Organizzazione responsabile dell'installazione, gestione e manutenzione dell'infrastruttura di ricarica"@it ;
                                                                                                rdfs:label "Operatore dei punti di ricarica"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/Citta
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/Citta> rdf:type owl:Class ;
                                                                                rdfs:comment "Entità territoriale urbana nella quale sono installate aree di ricarica."@it ;
                                                                                rdfs:label "Città"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/CittàSmart
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/CittàSmart> rdf:type owl:Class ;
                                                                                     owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/Citta>
                                                                                                                                [ rdf:type owl:Restriction ;
                                                                                                                                  owl:onProperty <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/haInstallatoArea> ;
                                                                                                                                  owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                                                                                                  owl:onClass [ owl:intersectionOf ( <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/AreaDiRicarica>
                                                                                                                                                                     [ rdf:type owl:Restriction ;
                                                                                                                                                                       owl:onProperty <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/contieneStazione> ;
                                                                                                                                                                       owl:someValuesFrom <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StazioneUltraVeloce>
                                                                                                                                                                     ]
                                                                                                                                                                   ) ;
                                                                                                                                                rdf:type owl:Class
                                                                                                                                              ]
                                                                                                                                ]
                                                                                                                              ) ;
                                                                                                           rdf:type owl:Class
                                                                                                         ] ;
                                                                                     rdfs:subClassOf <http://schema.org/City> ,
                                                                                                     <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/Citta> ;
                                                                                     rdfs:comment "Città caratterizzata dalla presenza di almeno due aree di ricarica contenenti stazioni ultra veloci."@it ;
                                                                                     rdfs:label "Città smart"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/Connettore
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/Connettore> rdf:type owl:Class ;
                                                                                     rdfs:comment "Dispositivo fisico che consente il collegamento tra il punto di ricarica e il veicolo elettrico"@it ;
                                                                                     rdfs:label "Connettore di Ricarica"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/Provincia
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/Provincia> rdf:type owl:Class .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/PuntoDiRicarica
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/PuntoDiRicarica> rdf:type owl:Class ;
                                                                                          rdfs:comment "Colonnina o presa di ricarica che mette a disposizione uno o più connettori."@it ;
                                                                                          rdfs:label "Punto di Ricarica"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StatoOperativo
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StatoOperativo> rdf:type owl:Class .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StatoStazione
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StatoStazione> rdf:type owl:Class ;
                                                                                        rdfs:subClassOf <http://www.ontologydesignpatterns.org/cp/owl/situation.owl#Situation> .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StazioneDiRicarica
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StazioneDiRicarica> rdf:type owl:Class ;
                                                                                             rdfs:comment "Infrastruttura composta da uno o più punti di ricarica destinati all'alimentazione di veicoli elettrici."@it ;
                                                                                             rdfs:label "Stazione di ricarica"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StazioneLenta
<http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StazioneLenta> rdf:type owl:Class ;
                                                                                        owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StazioneDiRicarica>
                                                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                                                     owl:onProperty <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/haTipologiaCorrente> ;
                                                                                                                                     owl:hasValue <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/AC>
                                                                                                                                   ]
                                                                                                                                 ) ;
                                                                                                              rdf:type owl:Class
                                                                                                            ] ;
                                                                                        rdfs:subClassOf <http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StazioneDiRicarica> ;
                                                                                        rdfs:comment "Stazione di ricarica che utilizza corrente alternata (AC)."@it ;
                                                                                        rdfs:label "Stazione di ricarica lenta"@it .


###  http://www.semanticweb.org/harbi/ontologies/2026/5/untitled-ontology-24/StazioneUltraVeloce
